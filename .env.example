# Copy to .env.local for local dev. NEVER commit .env or .env.local.

# ── Supabase ─────────────────────────────────────────────────────────────
# Get these from your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DB password — only needed for CLI ops (supabase link / supabase db push).
SUPABASE_DB_PASSWORD=your-db-password

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Bantu Niaga

# Set to true once Supabase SMTP or Resend is configured for sign-up emails.
# AUTH_REQUIRE_EMAIL_VERIFICATION=true

# ── AI (Phase 4+) ────────────────────────────────────────────────────────
# Preferred: ILMU (YTL AI Labs) — OpenAI-compatible, powers HR Assistant.
# Save via /super-admin/integrations/ilmu or set env fallbacks below.
# ILMU_API_KEY=sk-...
# ILMU_DEFAULT_MODEL=ilmu-mini-v3.3
# ILMU_API_BASE_URL=https://api.ilmu.ai/v1
#
# Fallback OpenAI (used only when ILMU is not configured):
# OPENAI_API_KEY=sk-...
# OPENAI_ORGANIZATION_ID=org-...
# OPENAI_DEFAULT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Platform integrations encryption ─────────────────────────────────────
# Required to save secrets in /super-admin/integrations. Generate with:
#   openssl rand -hex 32
# CRITICAL: do not rotate this once you have saved credentials — they
# become un-decryptable. To rotate safely you must decrypt → set new key
# → re-encrypt (a one-off script is in scripts/rotate-integration-key.ts).
INTEGRATION_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# ── Payments (Phase 1+) ──────────────────────────────────────────────────
# BILLPLZ_API_KEY=
# BILLPLZ_X_SIGNATURE_KEY=
# BILLPLZ_COLLECTION_ID=

# ── Email (later) ────────────────────────────────────────────────────────
# RESEND_API_KEY=

# Marketing > Broadcasts > Email channel (Resend). Optional; without these set,
# email broadcasts fail with email_channel_not_configured. WhatsApp click-to-chat
# broadcasts work without these.
RESEND_API_KEY=
MARKETING_FROM_EMAIL=

# ── Meta (Facebook + Instagram Business) integration (Marketing M7) ──────
# Create a Meta App at https://developers.facebook.com/apps/ (no fees).
# Add the products "Facebook Login for Business" and "Instagram Graph API".
# Under "Use cases" enable: pages_show_list, pages_read_engagement,
# pages_manage_posts, pages_read_user_content, instagram_basic,
# instagram_content_publish, instagram_manage_insights, business_management.
# The OAuth redirect URI MUST exactly match META_REDIRECT_URI in
# App Settings → Use cases → Facebook Login → Valid OAuth Redirect URIs.
#
# Server-only secrets — never expose to the browser.
# META_APP_ID=
# META_APP_SECRET=
# META_REDIRECT_URI=http://localhost:3000/api/social/meta/callback
# If META_REDIRECT_URI is omitted, the app derives it from
# NEXT_PUBLIC_APP_URL + "/api/social/meta/callback".

# ── PDPA / Privacy ───────────────────────────────────────────────────────
# Privacy notice version string captured against every consent grant.
# Bump this whenever the wording in app/legal/privacy/page.tsx materially
# changes so we can prove which version each user actually consented to.
PRIVACY_POLICY_VERSION=2026-06-14

# Required for /api/cron/privacy-sweep — the hourly worker that hard-deletes
# accounts past their 30-day grace window. Generate with
#   openssl rand -hex 32
# Vercel Cron auto-attaches this as `Authorization: Bearer $CRON_SECRET`
# when the env var is configured in your project.
CRON_SECRET=change-me-to-a-32-byte-hex-string
